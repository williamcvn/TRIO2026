<UserControl x:Class="TRIO2026.App.Controls.LoginOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Visibility="Collapsed">

    <!-- 全螢幕半透明遮罩 + 置中登入卡片 -->
    <Grid>
        <!-- 背景遮罩 -->
        <Border Background="#80000000" />

        <!-- 登入卡片 -->
        <Border x:Name="DialogCard"
                MaxWidth="380" MinWidth="300"
                VerticalAlignment="Center" HorizontalAlignment="Center"
                CornerRadius="16"
                Padding="28,24"
                Margin="32">
            <Border.Background>
                <SolidColorBrush Color="#1E2D45" Opacity="0.97" />
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="40" ShadowDepth="0" Opacity="0.5" />
            </Border.Effect>
            <Border.RenderTransform>
                <ScaleTransform x:Name="CardScale" ScaleX="1" ScaleY="1" />
            </Border.RenderTransform>
            <Border.RenderTransformOrigin>
                <Point X="0.5" Y="0.5" />
            </Border.RenderTransformOrigin>

            <StackPanel>
                <!-- 圖示 -->
                <TextBlock Text="🔐" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,8" />

                <!-- 標題 -->
                <TextBlock x:Name="TitleText"
                           Text="身分驗證"
                           FontSize="20" FontWeight="SemiBold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,4" />

                <!-- 說明 -->
                <TextBlock x:Name="SubtitleText"
                           Text="請輸入帳號密碼以進行身分確認"
                           FontSize="13"
                           Foreground="#78909C"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20" />

                <!-- 帳號輸入框 -->
                <Border Background="#354B70" CornerRadius="10"
                        BorderBrush="#4A6A9A" BorderThickness="1"
                        Height="48" Margin="0,0,0,10" Padding="14,0">
                    <TextBox x:Name="UsernameBox"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="#F0F4F8"
                             CaretBrush="#80D8FF"
                             FontSize="16" FontFamily="Segoe UI"
                             VerticalContentAlignment="Center" />
                </Border>

                <!-- 密碼輸入框 -->
                <Border Background="#354B70" CornerRadius="10"
                        BorderBrush="#4A6A9A" BorderThickness="1"
                        Height="48" Margin="0,0,0,6" Padding="14,0">
                    <PasswordBox x:Name="PasswordBox"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="#F0F4F8"
                                 CaretBrush="#80D8FF"
                                 FontSize="16" FontFamily="Segoe UI"
                                 VerticalContentAlignment="Center" />
                </Border>

                <!-- 錯誤訊息 -->
                <TextBlock x:Name="ErrorText"
                           Text=""
                           FontSize="13"
                           Foreground="#EF5350"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,16"
                           Visibility="Collapsed" />

                <!-- 確認按鈕 -->
                <Button x:Name="ConfirmButton"
                        Content="驗證"
                        Click="ConfirmButton_Click"
                        Width="240" Height="48"
                        FontSize="16" FontWeight="SemiBold"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Margin="0,0,0,8">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="#1B8A6B" CornerRadius="8" Padding="16,8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#14725A"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#4CAF50"/>
                                    <Setter TargetName="Bd" Property="BorderThickness" Value="2"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- 取消按鈕 -->
                <Button x:Name="CancelButton"
                        Content="取消"
                        Click="CancelButton_Click"
                        Width="240" Height="48"
                        FontSize="16"
                        Foreground="#78909C"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="Transparent"
                                    BorderBrush="#3D5577" BorderThickness="1"
                                    CornerRadius="8" Padding="16,8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#2A3D5E"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#78909C"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
