<UserControl x:Class="TRIO2026.App.Controls.ChangePasswordOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Visibility="Collapsed">

    <!-- 全螢幕半透明遮罩 + 置中密碼變更卡片 -->
    <Grid>
        <!-- 背景遮罩 -->
        <Border Background="#80000000" />

        <!-- 卡片 -->
        <Border x:Name="DialogCard"
                MaxWidth="540" MinWidth="440"
                VerticalAlignment="Center" HorizontalAlignment="Center"
                CornerRadius="20"
                Padding="36,32"
                Margin="32">
            <Border.Background>
                <SolidColorBrush Color="#1E2D45" Opacity="0.97" />
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="40" ShadowDepth="0" Opacity="0.5" />
            </Border.Effect>
            <Border.RenderTransform>
                <ScaleTransform x:Name="CardScale" ScaleX="1" ScaleY="1" />
            </Border.RenderTransform>
            <Border.RenderTransformOrigin>
                <Point X="0.5" Y="0.5" />
            </Border.RenderTransformOrigin>

            <StackPanel>
                <!-- 圖示 -->
                <TextBlock Text="🔑" FontSize="42" HorizontalAlignment="Center" Margin="0,0,0,10" />

                <!-- 標題 -->
                <TextBlock x:Name="TitleText"
                           Text="Change Password"
                           FontSize="24" FontWeight="SemiBold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,4" />

                <!-- 說明 -->
                <TextBlock x:Name="SubtitleText"
                           Text=""
                           FontSize="15"
                           Foreground="#78909C"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           Margin="0,0,0,20" />

                <!-- 當前密碼 -->
                <TextBlock x:Name="CurrentPasswordLabel" Text="Current Password"
                           FontSize="15" Foreground="#90A4AE" Margin="4,0,0,6" />
                <Border Background="#354B70" CornerRadius="12"
                        BorderBrush="#4A6A9A" BorderThickness="1"
                        Height="56" Margin="0,0,0,14">
                    <Grid>
                        <PasswordBox x:Name="CurrentPasswordBox"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="#F0F4F8"
                                     CaretBrush="#80D8FF"
                                     FontSize="20" FontFamily="Segoe UI"
                                     VerticalContentAlignment="Center"
                                     Margin="14,0,48,0"
                                     PasswordChanged="OnPasswordFieldChanged" />
                        <TextBox x:Name="CurrentPasswordPlain"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="#F0F4F8"
                                 CaretBrush="#80D8FF"
                                 FontSize="32" FontFamily="Segoe UI"
                                 VerticalContentAlignment="Center"
                                 Margin="14,0,48,0"
                                 Visibility="Collapsed"
                                 TextChanged="OnPlainTextChanged" />
                        <!-- 👁 顯示/隱藏 -->
                        <Button x:Name="ToggleCurrent" Click="OnToggleCurrentPassword"
                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                Width="48" Height="48" Cursor="Hand"
                                Margin="0,0,4,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="Transparent" CornerRadius="6">
                                        <TextBlock x:Name="EyeIcon" Text="👁" FontSize="18"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#2A3D5E"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>

                <!-- 新密碼 -->
                <TextBlock x:Name="NewPasswordLabel" Text="New Password"
                           FontSize="15" Foreground="#90A4AE" Margin="4,0,0,6" />
                <Border Background="#354B70" CornerRadius="12"
                        BorderBrush="#4A6A9A" BorderThickness="1"
                        Height="56" Margin="0,0,0,14">
                    <Grid>
                        <PasswordBox x:Name="NewPasswordBox"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="#F0F4F8"
                                     CaretBrush="#80D8FF"
                                     FontSize="20" FontFamily="Segoe UI"
                                     VerticalContentAlignment="Center"
                                     Margin="14,0,48,0"
                                     PasswordChanged="OnPasswordFieldChanged" />
                        <TextBox x:Name="NewPasswordPlain"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="#F0F4F8"
                                 CaretBrush="#80D8FF"
                                 FontSize="32" FontFamily="Segoe UI"
                                 VerticalContentAlignment="Center"
                                 Margin="14,0,48,0"
                                 Visibility="Collapsed"
                                 TextChanged="OnPlainTextChanged" />
                        <Button x:Name="ToggleNew" Click="OnToggleNewPassword"
                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                Width="48" Height="48" Cursor="Hand"
                                Margin="0,0,4,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="Transparent" CornerRadius="6">
                                        <TextBlock Text="👁" FontSize="18"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#2A3D5E"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>

                <!-- 確認密碼 -->
                <TextBlock x:Name="ConfirmPasswordLabel" Text="Confirm Password"
                           FontSize="15" Foreground="#90A4AE" Margin="4,0,0,6" />
                <Border Background="#354B70" CornerRadius="12"
                        BorderBrush="#4A6A9A" BorderThickness="1"
                        Height="56" Margin="0,0,0,8">
                    <Grid>
                        <PasswordBox x:Name="ConfirmPasswordBox"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="#F0F4F8"
                                     CaretBrush="#80D8FF"
                                     FontSize="20" FontFamily="Segoe UI"
                                     VerticalContentAlignment="Center"
                                     Margin="14,0,48,0"
                                     PasswordChanged="OnPasswordFieldChanged" />
                        <TextBox x:Name="ConfirmPasswordPlain"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="#F0F4F8"
                                 CaretBrush="#80D8FF"
                                 FontSize="32" FontFamily="Segoe UI"
                                 VerticalContentAlignment="Center"
                                 Margin="14,0,48,0"
                                 Visibility="Collapsed"
                                 TextChanged="OnPlainTextChanged" />
                        <Button x:Name="ToggleConfirm" Click="OnToggleConfirmPassword"
                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                Width="48" Height="48" Cursor="Hand"
                                Margin="0,0,4,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="Transparent" CornerRadius="6">
                                        <TextBlock Text="👁" FontSize="18"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#2A3D5E"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>

                <!-- 即時驗證規則提示 -->
                <ItemsControl x:Name="PolicyRulesPanel" Margin="4,8,0,8">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="{Binding Icon}" FontSize="16" Width="24" />
                                <TextBlock Text="{Binding Description}" FontSize="15"
                                           Foreground="{Binding Color}" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- 錯誤訊息 -->
                <TextBlock x:Name="ErrorText"
                           Text=""
                           FontSize="15"
                           Foreground="#EF5350"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12"
                           Visibility="Collapsed" />

                <!-- 提交按鈕 -->
                <Button x:Name="SubmitButton"
                        Content="Change Password"
                        Click="OnSubmitClick"
                        Width="360" Height="60"
                        FontSize="18" FontWeight="SemiBold"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Margin="0,0,0,8">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="#1B8A6B" CornerRadius="8" Padding="16,8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#14725A"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#4CAF50"/>
                                    <Setter TargetName="Bd" Property="BorderThickness" Value="2"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- 取消按鈕 -->
                <Button x:Name="CancelButton"
                        Content="Cancel"
                        Click="OnCancelClick"
                        Width="360" Height="52"
                        FontSize="17"
                        Foreground="#78909C"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="Transparent"
                                    BorderBrush="#3D5577" BorderThickness="1"
                                    CornerRadius="8" Padding="16,8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#2A3D5E"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#78909C"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
