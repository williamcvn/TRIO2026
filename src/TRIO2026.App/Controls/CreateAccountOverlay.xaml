<UserControl x:Class="TRIO2026.App.Controls.CreateAccountOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Visibility="Collapsed">

    <!-- 全螢幕半透明遮罩 + 置中新增帳號卡片 -->
    <Grid>
        <!-- 背景遮罩 -->
        <Border Background="#80000000" />

        <!-- 卡片 -->
        <Border x:Name="DialogCard"
                MaxWidth="500" MinWidth="420"
                VerticalAlignment="Center" HorizontalAlignment="Center"
                CornerRadius="20"
                Padding="36,32"
                Margin="32">
            <Border.Background>
                <SolidColorBrush Color="#1E2D45" Opacity="0.97" />
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="40" ShadowDepth="0" Opacity="0.5" />
            </Border.Effect>
            <Border.RenderTransform>
                <ScaleTransform x:Name="CardScale" ScaleX="1" ScaleY="1" />
            </Border.RenderTransform>
            <Border.RenderTransformOrigin>
                <Point X="0.5" Y="0.5" />
            </Border.RenderTransformOrigin>

            <StackPanel>
                <!-- 圖示 -->
                <TextBlock Text="👤" FontSize="42" HorizontalAlignment="Center" Margin="0,0,0,10" />

                <!-- 標題 -->
                <TextBlock x:Name="TitleText"
                           Text="Create Account"
                           FontSize="24" FontWeight="SemiBold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,16" />

                <!-- Username 欄位 -->
                <TextBlock x:Name="UsernameLabel" Text="Username"
                           FontSize="15" Foreground="#90A4AE" Margin="4,0,0,6" />
                <Border Background="#354B70" CornerRadius="12"
                        BorderBrush="#4A6A9A" BorderThickness="1"
                        Height="56" Margin="0,0,0,14" Padding="14,0">
                    <TextBox x:Name="UsernameBox"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="#F0F4F8"
                             CaretBrush="#80D8FF"
                             FontSize="20" FontFamily="Segoe UI"
                             VerticalContentAlignment="Center"
                             MaxLength="20" />
                </Border>

                <!-- Display Name 欄位 -->
                <TextBlock x:Name="DisplayNameLabel" Text="Display Name"
                           FontSize="15" Foreground="#90A4AE" Margin="4,0,0,6" />
                <Border Background="#354B70" CornerRadius="12"
                        BorderBrush="#4A6A9A" BorderThickness="1"
                        Height="56" Margin="0,0,0,14" Padding="14,0">
                    <TextBox x:Name="DisplayNameBox"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="#F0F4F8"
                             CaretBrush="#80D8FF"
                             FontSize="20" FontFamily="Segoe UI"
                             VerticalContentAlignment="Center"
                             MaxLength="50" />
                </Border>

                <!-- 角色選擇 -->
                <TextBlock x:Name="RoleLabel" Text="Role"
                           FontSize="15" Foreground="#90A4AE" Margin="4,0,0,6" />
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <!-- Operator 按鈕 -->
                    <Button x:Name="BtnRoleOperator" Click="OnRoleOperatorClick" Cursor="Hand"
                            Margin="0,0,8,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="#354B70"
                                        CornerRadius="8" Padding="20,12"
                                        BorderBrush="#4A6A9A" BorderThickness="1">
                                    <TextBlock x:Name="Txt" Text="Operator" FontSize="18"
                                               Foreground="#F0F4F8"
                                               HorizontalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#2A3D5E"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <!-- Admin 按鈕 -->
                    <Button x:Name="BtnRoleAdmin" Click="OnRoleAdminClick" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="#354B70"
                                        CornerRadius="8" Padding="20,12"
                                        BorderBrush="#4A6A9A" BorderThickness="1">
                                    <TextBlock x:Name="Txt" Text="Admin" FontSize="18"
                                               Foreground="#F0F4F8"
                                               HorizontalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#2A3D5E"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

                <!-- Service 帳號提示 -->
                <TextBlock x:Name="ServiceNotice" Text=""
                           FontSize="14" Foreground="#607D8B"
                           TextWrapping="Wrap"
                           Margin="4,0,0,4" />

                <!-- 初始密碼提示 -->
                <TextBlock x:Name="InitPasswordNotice" Text=""
                           FontSize="14" Foreground="#607D8B"
                           TextWrapping="Wrap"
                           Margin="4,0,0,12" />

                <!-- 錯誤訊息 -->
                <TextBlock x:Name="ErrorText"
                           Text=""
                           FontSize="15"
                           Foreground="#EF5350"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12"
                           Visibility="Collapsed" />

                <!-- 建立按鈕 -->
                <Button x:Name="CreateButton"
                        Content="Create"
                        Click="OnCreateClick"
                        Width="360" Height="60"
                        FontSize="18" FontWeight="SemiBold"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Margin="0,0,0,8">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="#1B8A6B" CornerRadius="8" Padding="16,8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#14725A"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- 取消按鈕 -->
                <Button x:Name="CancelButton"
                        Content="Cancel"
                        Click="OnCancelClick"
                        Width="360" Height="52"
                        FontSize="17"
                        Foreground="#78909C"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="Transparent"
                                    BorderBrush="#3D5577" BorderThickness="1"
                                    CornerRadius="8" Padding="16,8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#2A3D5E"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#78909C"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
