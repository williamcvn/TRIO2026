<UserControl x:Class="TRIO2026.App.Controls.OverlayDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Visibility="Collapsed">
    
    <!-- 全螢幕半透明遮罩 + 置中對話框 -->
    <Grid>
        <!-- 背景遮罩 -->
        <Border Background="#80000000" />
        
        <!-- 對話框卡片 -->
        <Border x:Name="DialogCard"
                MaxWidth="400" MinWidth="280"
                VerticalAlignment="Center" HorizontalAlignment="Center"
                CornerRadius="16"
                Padding="32,28"
                Margin="32">
            <Border.Background>
                <SolidColorBrush Color="#1E2D45" Opacity="0.97" />
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="40" ShadowDepth="0" Opacity="0.5" />
            </Border.Effect>
            <Border.RenderTransform>
                <ScaleTransform x:Name="CardScale" ScaleX="1" ScaleY="1" />
            </Border.RenderTransform>
            <Border.RenderTransformOrigin>
                <Point X="0.5" Y="0.5" />
            </Border.RenderTransformOrigin>
            
            <StackPanel>
                <!-- 圖示（帶底色圓角矩形） -->
                <Border x:Name="IconBorder"
                        Width="72" Height="72"
                        CornerRadius="16"
                        Background="#1A3A5C"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,12">
                    <TextBlock x:Name="IconText"
                               Text="✅"
                               FontSize="36"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
                
                <!-- 標題 -->
                <TextBlock x:Name="TitleText"
                           Text="標題"
                           FontSize="20" FontWeight="SemiBold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           Margin="0,0,0,8" />
                
                <!-- 訊息內容 -->
                <TextBlock x:Name="MessageText"
                           Text="訊息內容"
                           FontSize="14"
                           Foreground="#90A4AE"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           Margin="0,0,0,24" />
                
                <!-- 按鈕區 -->
                <StackPanel x:Name="ButtonPanel" HorizontalAlignment="Center">
                    <!-- 主按鈕 -->
                    <Button x:Name="PrimaryButton"
                            Content="確定"
                            Click="PrimaryButton_Click"
                            Width="200" Height="44"
                            FontSize="16" FontWeight="SemiBold"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Margin="0,0,0,8">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#1B8A6B" Offset="0" />
                                <GradientStop Color="#2BA88C" Offset="1" />
                            </LinearGradientBrush>
                        </Button.Background>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="8"
                                        Padding="16,8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    
                    <!-- 中間按鈕（預設隱藏，三選一模式用） -->
                    <Button x:Name="MiddleButton"
                            Content="中間選項"
                            Click="MiddleButton_Click"
                            Visibility="Collapsed"
                            Width="200" Height="44"
                            FontSize="16" FontWeight="SemiBold"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Margin="0,0,0,8">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border CornerRadius="8" Padding="16,8">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#EF5350" Offset="0" />
                                            <GradientStop Color="#E53935" Offset="1" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- 次要按鈕（取消，預設隱藏） -->
                    <Button x:Name="SecondaryButton"
                            Content="取消"
                            Click="SecondaryButton_Click"
                            Visibility="Collapsed"
                            Width="200" Height="44"
                            FontSize="16"
                            Foreground="#78909C"
                            Background="Transparent"
                            BorderThickness="1"
                            BorderBrush="#3D5577"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="8"
                                        Padding="16,8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
