<UserControl x:Class="TRIO2026.App.Controls.UvDoorErrorOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:svc="clr-namespace:TRIO2026.App.Services"
             Visibility="Collapsed"
             x:Name="OverlayRoot">

    <UserControl.Resources>
        <!-- 淡入動畫 -->
        <Storyboard x:Key="FadeIn">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.3"/>
        </Storyboard>
        <!-- 淡出動畫 -->
        <Storyboard x:Key="FadeOut">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.3"/>
        </Storyboard>
    </UserControl.Resources>

    <!-- 半透明深色遮罩 -->
    <Grid Background="#CC000000">
        <!-- 警示內容卡片 -->
        <Border Background="#FF2B2B2B"
                CornerRadius="16"
                Width="360" Height="380"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="30">
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center">

                <!-- 紅底白叉叉圓形圖案 -->
                <Grid Width="120" Height="120"
                      HorizontalAlignment="Center"
                      Margin="0,0,0,24">
                    <!-- 紅色圓底 -->
                    <Ellipse Fill="#E53935" Width="120" Height="120"/>
                    <!-- 白色叉叉 (X) -->
                    <Canvas Width="120" Height="120">
                        <Line X1="38" Y1="38" X2="82" Y2="82"
                              Stroke="White" StrokeThickness="8"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                        <Line X1="82" Y1="38" X2="38" Y2="82"
                              Stroke="White" StrokeThickness="8"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                        <!-- 白色斜條紋裝飾 -->
                        <Line X1="30" Y1="55" X2="55" Y2="30"
                              Stroke="#44FFFFFF" StrokeThickness="3"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                        <Line X1="65" Y1="90" X2="90" Y2="65"
                              Stroke="#44FFFFFF" StrokeThickness="3"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                    </Canvas>
                </Grid>

                <!-- Error! 標題 -->
                <TextBlock Text="{Binding [UV.DoorErrorTitle], Source={x:Static svc:LocalizationService.Instance}}"
                           FontSize="28" FontWeight="Bold"
                           Foreground="#FFFFFF"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,16"/>

                <!-- 錯誤訊息 -->
                <TextBlock Text="{Binding [UV.DoorErrorMessage], Source={x:Static svc:LocalizationService.Instance}}"
                           FontSize="16"
                           Foreground="#E53935"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           HorizontalAlignment="Center"
                           MaxWidth="280"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
