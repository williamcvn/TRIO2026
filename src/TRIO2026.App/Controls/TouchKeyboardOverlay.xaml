<UserControl x:Class="TRIO2026.App.Controls.TouchKeyboardOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:svc="clr-namespace:TRIO2026.App.Services"
             Visibility="Collapsed">

    <UserControl.Resources>
        <!-- 一般字元按鈕 — 觸控優化，無 Hover -->
        <Style x:Key="CharKey" TargetType="Button">
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="MinWidth" Value="50" />
            <Setter Property="Height" Value="52" />
            <Setter Property="Margin" Value="3" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="#3A5278"
                                CornerRadius="8"
                                BorderBrush="#4A6A9A" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#5580B0" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#80D8FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 功能按鈕（Shift / 符號切換 / 退格 / 空白 / 確認 / 取消） -->
        <Style x:Key="FuncKey" TargetType="Button">
            <Setter Property="FontSize" Value="17" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Height" Value="52" />
            <Setter Property="Margin" Value="3" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Tag}"
                                CornerRadius="8"
                                BorderBrush="#4A6A9A" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.7" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#80D8FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <!-- 半透明遮罩 -->
    <Grid Background="#CC1A2538">
        <!-- 鍵盤面板 — 底部對齊 -->
        <Border x:Name="KeyboardPanel"
                VerticalAlignment="Bottom" HorizontalAlignment="Stretch"
                CornerRadius="20,20,0,0"
                Padding="16,12,16,16"
                Margin="0">
            <Border.Background>
                <SolidColorBrush Color="#2A3A5C" Opacity="0.98" />
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="30" ShadowDepth="-2" Opacity="0.5" />
            </Border.Effect>

            <StackPanel>
                <!-- 頂部：輸入顯示 + 標題 + 關閉 -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <!-- 標題（輸入帳號 / 輸入密碼） -->
                    <TextBlock x:Name="TitleText" Grid.Column="0"
                               Text="{Binding [TouchKeyboard.TitleAccount], Source={x:Static svc:LocalizationService.Instance}}"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="#B0BEC5"
                               VerticalAlignment="Center" Margin="8,0" />
                    <!-- 輸入顯示區 -->
                    <Border Grid.Column="1" Background="#1E2D45" CornerRadius="8"
                            Height="44" Margin="8,0" Padding="12,0"
                            BorderBrush="#4A6A9A" BorderThickness="1"
                            ClipToBounds="True">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="40" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="InputDisplay" Grid.Column="0"
                                       Text="" FontSize="20" FontWeight="SemiBold"
                                       FontFamily="Consolas"
                                       Foreground="#F0F4F8"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" />
                            <Button x:Name="EyeToggle" Grid.Column="1"
                                    Content="👁" FontSize="18"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="#6688AA"
                                    HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Width="40" Height="40"
                                    Click="EyeToggle_Click" Cursor="Hand"
                                    Visibility="Collapsed">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="Transparent" CornerRadius="6">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Border>
                    <!-- 關閉 -->
                    <Button Grid.Column="2" Content="✕"
                            FontSize="20" Foreground="#90A4AE"
                            Width="44" Height="44"
                            Click="CancelButton_Click" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="#3A4A6A" CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Opacity" Value="0.6" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <!-- 鍵盤區域 — 由 code-behind 動態產生（固定高度避免切換時版面跳動） -->
                <StackPanel x:Name="KeyboardRows" HorizontalAlignment="Center"
                            MinHeight="295" VerticalAlignment="Top" />
            </StackPanel>
        </Border>

        <!-- 隱藏焦點接收器：攔截實體鍵盤輸入 -->
        <TextBox x:Name="FocusCatcher"
                 Opacity="0" Width="0" Height="0"
                 IsReadOnly="False"
                 PreviewTextInput="FocusCatcher_PreviewTextInput"
                 PreviewKeyDown="FocusCatcher_PreviewKeyDown" />
    </Grid>
</UserControl>
