<UserControl x:Class="TRIO2026.App.Views.Pages.LoginPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:TRIO2026.App.Converters"
             xmlns:controls="clr-namespace:TRIO2026.App.Controls">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <Color x:Key="PrimaryBlue">#42A5F5</Color>
        <Color x:Key="AccentTeal">#26C6DA</Color>
        <Color x:Key="ErrorRed">#EF5350</Color>
        <Color x:Key="TextPrimary">#F0F4F8</Color>
        <Color x:Key="TextSecondary">#B0BEC5</Color>
        <Color x:Key="CardBg">#2A3A5C</Color>

        <SolidColorBrush x:Key="PrimaryBlueBrush" Color="{StaticResource PrimaryBlue}" />
        <SolidColorBrush x:Key="ErrorRedBrush" Color="{StaticResource ErrorRed}" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}" />

        <Style x:Key="InnerTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#F0F4F8" />
            <Setter Property="CaretBrush" Value="#80D8FF" />
            <Setter Property="SelectionBrush" Value="#5542A5F5" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="4,0" />
        </Style>

        <Style x:Key="InnerPasswordBox" TargetType="PasswordBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#F0F4F8" />
            <Setter Property="CaretBrush" Value="#80D8FF" />
            <Setter Property="SelectionBrush" Value="#5542A5F5" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="4,0" />
        </Style>

        <Style x:Key="InputBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#354B70" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="BorderBrush" Value="#4A6A9A" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="Height" Value="56" />
            <Setter Property="Padding" Value="16,0" />
        </Style>

        <Style x:Key="LoginButton" TargetType="Button">
            <Setter Property="Height" Value="56" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder" CornerRadius="12" Padding="0,12">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="{StaticResource PrimaryBlue}" Offset="0" />
                                    <GradientStop Color="{StaticResource AccentTeal}" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.8" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="White"/>
                                <Setter TargetName="ButtonBorder" Property="BorderThickness" Value="2"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TouchCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="MinHeight" Value="48" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Storyboard x:Key="ShakeAnimation">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)">
                <EasingDoubleKeyFrame KeyTime="0:0:0.0" Value="0" />
                <EasingDoubleKeyFrame KeyTime="0:0:0.05" Value="-10" />
                <EasingDoubleKeyFrame KeyTime="0:0:0.1" Value="10" />
                <EasingDoubleKeyFrame KeyTime="0:0:0.15" Value="-8" />
                <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="8" />
                <EasingDoubleKeyFrame KeyTime="0:0:0.25" Value="-4" />
                <EasingDoubleKeyFrame KeyTime="0:0:0.3" Value="4" />
                <EasingDoubleKeyFrame KeyTime="0:0:0.35" Value="0" />
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
    </UserControl.Resources>

    <Grid>
        <!-- 關閉按鈕（右上角） -->
        <Button x:Name="CloseButton"
                Content="✕"
                FontSize="20" FontWeight="Light"
                Foreground="#6688AA"
                Background="Transparent"
                BorderThickness="0"
                Width="48" Height="48"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,8,12,0"
                Cursor="Hand"
                Click="CloseButton_Click"
                Visibility="Collapsed"
                ToolTip="關閉應用程式">
            <Button.Style>
                <Style TargetType="Button">
                </Style>
            </Button.Style>
        </Button>

        <!-- 登入卡片 -->
        <Border x:Name="LoginCard"
                Width="480"
                VerticalAlignment="Center" HorizontalAlignment="Center"
                CornerRadius="24"
                Padding="48,40">
            <Border.Background>
                <SolidColorBrush Color="{StaticResource CardBg}" Opacity="0.92" />
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="50" ShadowDepth="0" Opacity="0.4" />
            </Border.Effect>
            <Border.RenderTransform>
                <TranslateTransform />
            </Border.RenderTransform>

            <StackPanel>
                <TextBlock Text="TRIO2026"
                           FontSize="36" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,4" />
                <TextBlock Text="Automated Sample Preparation System"
                           FontSize="13"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8" />

                <!-- 頭像 -->
                <Border Width="96" Height="96" CornerRadius="48"
                        BorderBrush="{StaticResource PrimaryBlueBrush}" BorderThickness="3"
                        HorizontalAlignment="Center" Margin="0,12,0,24">
                    <Border.Background>
                        <SolidColorBrush Color="#354B70" />
                    </Border.Background>
                    <TextBlock Text="👤" FontSize="40"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <Border.Clip>
                        <EllipseGeometry Center="48,48" RadiusX="48" RadiusY="48" />
                    </Border.Clip>
                </Border>

                <TextBlock Text="帳號" FontSize="14"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="4,0,0,6" />

                <!-- 帳號輸入：文字框 / 下拉選單（互斥顯示） -->
                <Grid Margin="0,0,0,16">
                    <!-- 文字輸入框（show_user_dropdown=0 時顯示） -->
                    <Border Style="{StaticResource InputBorderStyle}"
                            x:Name="UsernameBorder"
                            Visibility="{Binding ShowUserDropdown, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                        <TextBox x:Name="UsernameBox"
                                 Style="{StaticResource InnerTextBox}"
                                 Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                 TabIndex="0"
                                 GotFocus="InputBox_GotFocus"
                                 LostFocus="InputBox_LostFocus" />
                    </Border>

                    <!-- 下拉選單（show_user_dropdown=1 時顯示） -->
                    <Border Style="{StaticResource InputBorderStyle}"
                            x:Name="UserDropdownBorder"
                            Visibility="{Binding ShowUserDropdown, Converter={StaticResource BoolToVis}}">
                        <ComboBox x:Name="UserDropdown"
                                  ItemsSource="{Binding UserList}"
                                  SelectedItem="{Binding SelectedUser}"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  Foreground="White"
                                  FontSize="22" FontWeight="SemiBold" FontFamily="Segoe UI"
                                  VerticalContentAlignment="Center"
                                  TabIndex="0"
                                  SelectionChanged="UserDropdown_SelectionChanged">

                            <!-- ComboBox 完整自訂模板：透明底色 + 深色下拉 -->
                            <ComboBox.Template>
                                <ControlTemplate TargetType="ComboBox">
                                    <Grid>
                                        <!-- 觸控按鈕（透明，不遮擋底色） -->
                                        <ToggleButton x:Name="ToggleBtn"
                                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                      Background="Transparent" BorderThickness="0"
                                                      Focusable="False" ClickMode="Press">
                                            <ToggleButton.Template>
                                                <ControlTemplate TargetType="ToggleButton">
                                                    <Border Background="Transparent">
                                                        <TextBlock Text="▾" Foreground="#80D8FF"
                                                                   FontSize="20" FontWeight="Bold"
                                                                   HorizontalAlignment="Right"
                                                                   VerticalAlignment="Center"
                                                                   Margin="0,0,4,0" />
                                                    </Border>
                                                </ControlTemplate>
                                            </ToggleButton.Template>
                                        </ToggleButton>

                                        <!-- 選中項顯示區（白色文字，透明底色） -->
                                        <ContentPresenter x:Name="ContentSite"
                                                          Content="{TemplateBinding SelectionBoxItem}"
                                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                          IsHitTestVisible="False"
                                                          VerticalAlignment="Center"
                                                          HorizontalAlignment="Left"
                                                          Margin="4,0,24,0" />

                                        <!-- 下拉彈出 -->
                                        <Popup x:Name="PART_Popup"
                                               IsOpen="{TemplateBinding IsDropDownOpen}"
                                               Placement="Bottom"
                                               AllowsTransparency="True"
                                               Focusable="False"
                                               PopupAnimation="Slide">
                                            <Border Background="#1E2D45"
                                                    BorderBrush="#4A6A9A" BorderThickness="1"
                                                    CornerRadius="8" Padding="0,4"
                                                    MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                                    MinWidth="{TemplateBinding ActualWidth}">
                                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                    <StackPanel IsItemsHost="True" />
                                                </ScrollViewer>
                                            </Border>
                                        </Popup>
                                    </Grid>
                                </ControlTemplate>
                            </ComboBox.Template>

                            <!-- 觸控環境：無 hover 效果 -->
                            <ComboBox.ItemContainerStyle>
                                <Style TargetType="ComboBoxItem">
                                    <Setter Property="Background" Value="#1E2D45" />
                                    <Setter Property="Foreground" Value="White" />
                                    <Setter Property="Padding" Value="12,10" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ComboBoxItem">
                                                <Border x:Name="Bd"
                                                        Background="{TemplateBinding Background}"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsHighlighted" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#1E2D45" />
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#2A3D5E" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ComboBox.ItemContainerStyle>

                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   Foreground="White" FontSize="20" FontWeight="SemiBold"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding Username, StringFormat=' ({0})'}"
                                                   Foreground="#90CAF9" FontSize="15"
                                                   VerticalAlignment="Center" Margin="6,0,0,0" />
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </Border>
                </Grid>

                <TextBlock Text="密碼" FontSize="14"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="4,0,0,6" />
                <Border Style="{StaticResource InputBorderStyle}" Margin="0,0,0,16"
                        x:Name="PasswordBorder">
                    <PasswordBox x:Name="PasswordBox"
                                 Style="{StaticResource InnerPasswordBox}"
                                 TabIndex="1"
                                 PasswordChanged="PasswordBox_PasswordChanged"
                                 GotFocus="InputBox_GotFocus"
                                 LostFocus="InputBox_LostFocus" />
                </Border>

                <CheckBox Content="記住密碼"
                          Style="{StaticResource TouchCheckBox}"
                          IsChecked="{Binding RememberMe}"
                          Margin="4,0,0,20" TabIndex="2" />

                <Border x:Name="ErrorBorder"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}"
                        Background="#33EF5350" CornerRadius="8" Padding="12,8" Margin="0,0,0,16">
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="{StaticResource ErrorRedBrush}"
                               FontSize="14" TextWrapping="Wrap" HorizontalAlignment="Center" />
                </Border>

                <Button Content="登　入"
                        Style="{StaticResource LoginButton}"
                        Command="{Binding LoginCommand}"
                        IsDefault="True" TabIndex="3" />

                <TextBlock Text="{Binding ScreenInfo}"
                           FontSize="11" Foreground="#5577AA"
                           HorizontalAlignment="Center" Margin="0,20,0,0" />
            </StackPanel>
        </Border>

        <TextBlock Text="v1.0.0 — TRIO2026 © PlexBio"
                   FontSize="11" Foreground="#5577AA"
                   HorizontalAlignment="Right" VerticalAlignment="Bottom"
                   Margin="0,0,20,12" />
    </Grid>
</UserControl>
