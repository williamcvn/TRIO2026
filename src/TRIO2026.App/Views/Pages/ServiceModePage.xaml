<UserControl x:Class="TRIO2026.App.Views.Pages.ServiceModePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:TRIO2026.App.Controls"
             xmlns:svc="clr-namespace:TRIO2026.App.Services">

    <Grid Background="#0D1B2A">
        <!-- Service Mode 識別內容 -->
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="🔧" FontSize="48" HorizontalAlignment="Center"
                       Margin="0,0,0,16"/>
            <TextBlock Text="{Binding [ServiceMode.Title], Source={x:Static svc:LocalizationService.Instance}}"
                       FontSize="32" FontWeight="Bold"
                       Foreground="#F0F4F8" HorizontalAlignment="Center"
                       Margin="0,0,0,8"/>
            <TextBlock Text="{Binding [ServiceMode.Placeholder], Source={x:Static svc:LocalizationService.Instance}}"
                       FontSize="16"
                       Foreground="#7B8FA8" HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- 共用使用者選單（覆蓋在最上層） -->
        <controls:UserMenuControl x:Name="UserMenu"/>
    </Grid>

</UserControl>
