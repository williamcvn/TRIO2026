<UserControl x:Class="TRIO2026.App.Views.Pages.AccountManagementPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="clr-namespace:TRIO2026.App.Controls"
      xmlns:svc="clr-namespace:TRIO2026.App.Services"
      Background="#0F1923">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- 頂部標題列 -->
            <RowDefinition Height="*"/>      <!-- 主要內容 -->
        </Grid.RowDefinitions>

        <!-- ═══ 頂部標題列 ═══ -->
        <Border Grid.Row="0" Background="#162233" Padding="24,16">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="👥" FontSize="26" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <TextBlock x:Name="PageTitle" Text="Account Management"
                               FontSize="22" FontWeight="SemiBold"
                               Foreground="#F0F4F8" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ 主要內容區 ═══ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>     <!-- 左側：帳號列表 -->
                <ColumnDefinition Width="1.2*"/>  <!-- 右側：操作 / 詳細資料 -->
            </Grid.ColumnDefinitions>

            <!-- ═══ 左側：帳號列表 ═══ -->
            <Border Grid.Column="0" Margin="16,16,8,16"
                    Background="#162233" CornerRadius="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 列表頂部：新增帳號按鈕 -->
                    <Button x:Name="BtnAddAccount" Grid.Row="0"
                            Click="OnAddAccountClick" Cursor="Hand"
                            Margin="12,12,12,4">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="#1B8A6B"
                                        CornerRadius="8" Padding="14,12">
                                    <TextBlock x:Name="BtnAddText" Text="+ Add Account"
                                               FontSize="16" FontWeight="SemiBold"
                                               Foreground="White"
                                               HorizontalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#14725A"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- 帳號列表 -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                  Margin="8,4,8,8">
                        <ItemsControl x:Name="UserListPanel">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Click="OnUserItemClick"
                                            Tag="{Binding Id}" Cursor="Hand"
                                            Margin="4,2">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" Background="#1A2D47"
                                                        CornerRadius="8" Padding="14,12"
                                                        BorderBrush="#2A3D5E" BorderThickness="1">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock Text="{Binding DisplayLabel}"
                                                                       FontSize="16" FontWeight="SemiBold"
                                                                       Foreground="#F0F4F8"/>
                                                            <TextBlock Text="{Binding SubLabel}"
                                                                       FontSize="13"
                                                                       Foreground="#78909C"/>
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="1" Text="{Binding StatusIcon}"
                                                                   FontSize="14" VerticalAlignment="Center"
                                                                   Foreground="{Binding StatusColor}"/>
                                                    </Grid>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#2A4060"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- ═══ 右側：操作/詳細面板 ═══ -->
            <Border Grid.Column="1" Margin="8,16,16,16"
                    Background="#162233" CornerRadius="12" Padding="20">
                <Grid>
                    <!-- 初始提示（未選擇帳號時顯示） -->
                    <StackPanel x:Name="EmptyPrompt"
                                VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="👤" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,12" />
                        <TextBlock x:Name="SelectPromptText"
                                   Text="Select an account to manage"
                                   FontSize="17" Foreground="#607D8B"
                                   HorizontalAlignment="Center" />
                    </StackPanel>

                    <!-- 操作面板（選擇帳號後顯示） -->
                    <StackPanel x:Name="OperationsPanel" Visibility="Collapsed">
                        <!-- 選中帳號顯示 -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Border Background="#263B5E" CornerRadius="24" Width="48" Height="48"
                                    VerticalAlignment="Center" Margin="0,0,12,0">
                                <TextBlock Text="👤" FontSize="22"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="SelectedUserName"
                                           FontSize="18" FontWeight="SemiBold"
                                           Foreground="#F0F4F8"/>
                                <TextBlock x:Name="SelectedUserRole"
                                           FontSize="13" Foreground="#78909C"/>
                            </StackPanel>
                        </StackPanel>

                        <Border Height="1" Background="#2A3D5E" Margin="0,0,0,16"/>

                        <!-- 操作按鈕群 -->
                        <WrapPanel x:Name="ActionButtonsPanel">
                            <!-- 動態產生按鈕 -->
                        </WrapPanel>
                    </StackPanel>

                    <!-- 詳細資料面板（點擊 ViewDetails 後顯示） -->
                    <ScrollViewer x:Name="DetailsPanel" Visibility="Collapsed"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Button x:Name="BtnBackToOps" Click="OnBackToOpsClick" Cursor="Hand"
                                    Margin="0,0,0,16">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="Transparent"
                                                CornerRadius="8" Padding="12,8">
                                            <TextBlock x:Name="BackText" Text="← Back to Operations"
                                                       FontSize="15" Foreground="#4FC3F7"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#1A2D47"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <ItemsControl x:Name="DetailsItemsPanel">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,0,0,12">
                                            <TextBlock Text="{Binding Label}"
                                                       FontSize="12" Foreground="#607D8B"
                                                       Margin="0,0,0,2"/>
                                            <TextBlock Text="{Binding Value}"
                                                       FontSize="15" Foreground="#F0F4F8"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══ Overlay 元件 ═══ -->
        <controls:OverlayDialog x:Name="DialogOverlay" Grid.RowSpan="2"/>
        <controls:LoginOverlay x:Name="LoginOverlayHost" Grid.RowSpan="2"/>
        <controls:ChangePasswordOverlay x:Name="ChangePasswordOverlayHost" Grid.RowSpan="2"/>
        <controls:CreateAccountOverlay x:Name="CreateAccountOverlayHost" Grid.RowSpan="2"/>
        <controls:UserMenuControl x:Name="UserMenu" Grid.RowSpan="2"/>
    </Grid>
</UserControl>
