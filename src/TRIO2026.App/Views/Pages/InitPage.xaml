<UserControl x:Class="TRIO2026.App.Views.Pages.InitPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Color x:Key="PrimaryBlue">#42A5F5</Color>
        <Color x:Key="AccentTeal">#26C6DA</Color>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F0F4F8" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#B0BEC5" />

        <Storyboard x:Key="SpinAnimation" RepeatBehavior="Forever">
            <DoubleAnimation
                Storyboard.TargetName="SpinnerRotation"
                Storyboard.TargetProperty="Angle"
                From="0" To="360" Duration="0:0:1.2" />
        </Storyboard>

        <Storyboard x:Key="PulseAnimation" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation
                Storyboard.TargetName="StatusText"
                Storyboard.TargetProperty="Opacity"
                From="1" To="0.4" Duration="0:0:1" />
        </Storyboard>
    </UserControl.Resources>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="UserControl.Loaded">
            <BeginStoryboard Storyboard="{StaticResource SpinAnimation}" />
            <BeginStoryboard Storyboard="{StaticResource PulseAnimation}" />
        </EventTrigger>
    </UserControl.Triggers>

    <Grid>
        <!-- 裝飾圓形（左上） -->
        <Ellipse Width="400" Height="400"
                 HorizontalAlignment="Left" VerticalAlignment="Top"
                 Margin="-150,-100,0,0" Opacity="0.04">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#42A5F5" Offset="0" />
                    <GradientStop Color="Transparent" Offset="1" />
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <Ellipse Width="500" Height="500"
                 HorizontalAlignment="Right" VerticalAlignment="Bottom"
                 Margin="0,0,-180,-120" Opacity="0.03">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#26C6DA" Offset="0" />
                    <GradientStop Color="Transparent" Offset="1" />
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <!-- 主內容 -->
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="TRIO" FontSize="72" FontWeight="Bold" FontFamily="Segoe UI"
                       HorizontalAlignment="Center">
                <TextBlock.Foreground>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="{StaticResource PrimaryBlue}" Offset="0" />
                        <GradientStop Color="{StaticResource AccentTeal}" Offset="1" />
                    </LinearGradientBrush>
                </TextBlock.Foreground>
            </TextBlock>

            <TextBlock Text="2026" FontSize="36" FontWeight="Light" FontFamily="Segoe UI"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       HorizontalAlignment="Center" Margin="0,-8,0,0" />

            <TextBlock Text="Molecular Diagnostics Platform"
                       FontSize="14" FontWeight="Normal" FontFamily="Segoe UI"
                       Foreground="#607D8B"
                       HorizontalAlignment="Center" Margin="0,8,0,60" />

            <!-- 旋轉進度環 -->
            <Canvas Width="60" Height="60" HorizontalAlignment="Center" Margin="0,0,0,30">
                <Ellipse Width="60" Height="60" Stroke="#1E3A5F" StrokeThickness="3" />
                <Path Stroke="{StaticResource TextPrimaryBrush}" StrokeThickness="3"
                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                      Data="M 30,3 A 27,27 0 0 1 57,30"
                      RenderTransformOrigin="0.5,0.5">
                    <Path.RenderTransform>
                        <RotateTransform x:Name="SpinnerRotation" Angle="0" CenterX="30" CenterY="30" />
                    </Path.RenderTransform>
                </Path>
            </Canvas>

            <TextBlock x:Name="StatusText" Text="System Initializing..."
                       FontSize="18" FontFamily="Segoe UI"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       HorizontalAlignment="Center" Margin="0,0,0,16" />

            <TextBlock x:Name="CountdownText" Text="10"
                       FontSize="28" FontWeight="SemiBold" FontFamily="Segoe UI"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       HorizontalAlignment="Center" />
        </StackPanel>

        <TextBlock Text="v2026.1.0" FontSize="12" FontFamily="Segoe UI"
                   Foreground="#37474F"
                   HorizontalAlignment="Center" VerticalAlignment="Bottom"
                   Margin="0,0,0,30" />
    </Grid>
</UserControl>
