<UserControl x:Class="TRIO2026.App.Views.Pages.MenuPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:TRIO2026.App.Controls"
             xmlns:svc="clr-namespace:TRIO2026.App.Services">

    <UserControl.Resources>
        <Color x:Key="PrimaryBlue">#42A5F5</Color>
        <Color x:Key="AccentTeal">#26C6DA</Color>
        <Color x:Key="TextPrimary">#F0F4F8</Color>
        <Color x:Key="TextSecondary">#B0BEC5</Color>

        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}" />

        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="CardBorder"
                                Background="#1E2D4A" CornerRadius="16"
                                BorderBrush="#2A3D5E" BorderThickness="1"
                                Padding="20" MinHeight="160">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="12" ShadowDepth="2"
                                                  Color="#000000" Opacity="0.3" />
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="CardBorder" Property="Background" Value="#2A4570" />
                                <Setter TargetName="CardBorder" Property="BorderBrush" Value="#64B5F6" />
                                <Setter TargetName="CardBorder" Property="BorderThickness" Value="2" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="CardBorder" Property="Opacity" Value="0.35" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>

        <!-- ═══════ 頂部列 ═══════ -->
        <Border Grid.Row="0" Background="#15203A" BorderBrush="#1E3050" BorderThickness="0,0,0,1">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="TRIO" FontSize="26" FontWeight="Bold" FontFamily="Segoe UI"
                               VerticalAlignment="Center">
                        <TextBlock.Foreground>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="{StaticResource PrimaryBlue}" Offset="0" />
                                <GradientStop Color="{StaticResource AccentTeal}" Offset="1" />
                            </LinearGradientBrush>
                        </TextBlock.Foreground>
                    </TextBlock>
                    <TextBlock Text="2026" FontSize="16" FontWeight="Light" FontFamily="Segoe UI"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="4,4,0,0" />
                </StackPanel>

                <!-- 右上角使用者圖示由 UserMenuControl 提供 -->
            </Grid>
        </Border>

        <!-- ═══════ 中央功能按鈕區 ═══════ -->
        <Grid Grid.Row="1" Margin="24,30,24,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="1.2*"/>
                <RowDefinition Height="1.2*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="BtnIntelliPlex" Grid.Row="0" Grid.Column="0" Style="{StaticResource MenuButton}" Click="OnIntelliPlexClick">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="🧬" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,8" />
                    <TextBlock Text="{Binding [Menu.IntelliPlex], Source={x:Static svc:LocalizationService.Instance}}"
                               FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding [Menu.IntelliPlexSub], Source={x:Static svc:LocalizationService.Instance}}"
                               FontSize="18"
                               Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" />
                </StackPanel>
            </Button>

            <Button x:Name="BtnCustom" Grid.Row="0" Grid.Column="1" Style="{StaticResource MenuButton}" Click="OnCustomClick">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="🧪" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,8" />
                    <TextBlock Text="{Binding [Menu.Custom], Source={x:Static svc:LocalizationService.Instance}}"
                               FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding [Menu.CustomSub], Source={x:Static svc:LocalizationService.Instance}}"
                               FontSize="18"
                               Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" />
                </StackPanel>
            </Button>

            <Button Grid.Row="1" Grid.Column="0" Style="{StaticResource MenuButton}" Click="OnDataClick">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="📊" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,8" />
                    <TextBlock Text="{Binding [Menu.Data], Source={x:Static svc:LocalizationService.Instance}}"
                               FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding [Menu.DataSub], Source={x:Static svc:LocalizationService.Instance}}"
                               FontSize="18"
                               Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" />
                </StackPanel>
            </Button>

            <Button Grid.Row="1" Grid.Column="1" Style="{StaticResource MenuButton}" Click="OnSettingClick">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="🛠" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,8" />
                    <TextBlock Text="{Binding [Menu.Setting], Source={x:Static svc:LocalizationService.Instance}}"
                               FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding [Menu.SettingSub], Source={x:Static svc:LocalizationService.Instance}}"
                               FontSize="18"
                               Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" />
                </StackPanel>
            </Button>

            <Button Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                    Style="{StaticResource MenuButton}" Click="OnUVClick">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="💡" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,6" />
                    <TextBlock Text="{Binding [Menu.UV], Source={x:Static svc:LocalizationService.Instance}}"
                               FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding [Menu.UVSub], Source={x:Static svc:LocalizationService.Instance}}"
                               FontSize="18"
                               Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- ═══════ 底部列 ═══════ -->
        <Border Grid.Row="2" Background="#0C1524">
            <Grid Margin="20,0">
                <TextBlock Text="TRIO2026 v2026.1.0" FontSize="11" FontFamily="Segoe UI"
                           Foreground="#37474F" VerticalAlignment="Center" HorizontalAlignment="Left" />
                <TextBlock x:Name="StatusText"
                           Text="{Binding [Menu.StatusReady], Source={x:Static svc:LocalizationService.Instance}}"
                           FontSize="11" FontFamily="Segoe UI"
                           Foreground="#4CAF50" VerticalAlignment="Center" HorizontalAlignment="Right" />
            </Grid>
        </Border>

        <!-- ═══ 共用使用者選單（無 HOME 按鈕） ═══ -->
        <controls:UserMenuControl x:Name="UserMenu" Grid.RowSpan="3"
                                  ShowHomeButton="False"/>
    </Grid>
</UserControl>
